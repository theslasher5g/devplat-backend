# --- Core ---------------------------------------------------------------
# Inside the compose network Postgres is reachable as "postgres:5432"
DATABASE_URL=postgres://devplat:CHANGE_ME@postgres:5432/devplat
# openssl rand -hex 32
JWT_SECRET=CHANGE_ME
PORT=3000
HOST=0.0.0.0

# Public URL of the frontend (CORS origin, links in emails)
FRONTEND_URL=https://devplat.ch
# Public URL of this API (Stripe return URLs are derived from FRONTEND_URL,
# webhook endpoint is API_URL/webhooks/stripe)
API_URL=https://api.devplat.ch

# Cookie domain so devplat.ch and api.devplat.ch share the session cookie.
# Leave empty for local development (host-only cookie on localhost).
COOKIE_DOMAIN=.devplat.ch

# --- Resend ---------------------------------------------------------------
RESEND_API_KEY=re_CHANGE_ME
# NOTE: DNS/SPF/DKIM for this sender domain is NOT set up yet (infra task).
# Until it is, use Resend's onboarding sender or a verified domain.
EMAIL_FROM=devplat <noreply@devplat.dev>
# Inbox that receives "Book a call" / contact-form notifications.
CONTACT_EMAIL=hello@devplat.dev

# --- Stripe ---------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
# Created by `npm run stripe:setup` (prints these IDs)
STRIPE_PRICE_SOLO_MONTHLY=price_...
STRIPE_PRICE_SOLO_YEARLY=price_...
STRIPE_PRICE_TEAM_MONTHLY=price_...
STRIPE_PRICE_TEAM_YEARLY=price_...
STRIPE_PRICE_SCALE_MONTHLY=price_...
STRIPE_PRICE_SCALE_YEARLY=price_...

# --- Scheduler / Firecracker data plane ------------------------------------
# Per-VM sizing is NOT configured here anymore — it's the requesting team's
# plan cap (plans.vcpu_per_environment / ram_gb_per_environment), looked up per
# request and passed to the agent as that VM's hard limit. Edit the `plans`
# table (migrations/003_plans.sql) to change tier caps.
# A host is marked offline if neither its heartbeat nor a scheduler-initiated
# health poll succeeds within this many seconds.
AGENT_HEARTBEAT_TIMEOUT_SECONDS=90
# How often the queue worker retries queued environment requests and the
# health poller checks all agents.
SCHEDULER_POLL_INTERVAL_MS=5000
# Hosts themselves (agent_endpoint, agent_token, wireguard_ip, capacity) are
# registered at runtime via POST /admin/hosts, not env vars — see
# devplat-agent's README for the registration walkthrough.
